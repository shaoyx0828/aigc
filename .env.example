# SQLite 数据库文件路径（相对于项目根目录）
DATABASE_URL="file:./dev.db"

# —— 超级管理员（题库 / 会话 / 导出排行榜）——
# 登录地址：/admin/login
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-strong-password"
# 用于签发 HttpOnly Cookie，请使用 ≥32 字符随机串（勿泄露）
ADMIN_SESSION_SECRET="replace-with-a-long-random-secret-at-least-32-chars"

# 答题页主持人：默认若存在 public/avatar/idle-0.mp4 则优先用透明底视频；设为 1 可强制用 3D GLB
# NEXT_PUBLIC_QUIZ_AVATAR_FORCE_GLB="1"

# —— 语音播报（外部 TTS 优先，浏览器 speechSynthesis 兜底）——
# NEXT_PUBLIC_TTS_ENGINE=external
# NEXT_PUBLIC_TTS_API_URL=/api/tts
# NEXT_PUBLIC_TTS_FALLBACK=browser
# 外部 TTS fetch 超时基线（毫秒），默认 12000；业务层会与 25000 取较大值，避免单次 Edge 合成略慢即断
# NEXT_PUBLIC_TTS_TIMEOUT_MS=12000
